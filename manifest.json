{
    "manifest_version": 3,
    "name": "CW ticket tracker",
    "description": "Sends out an email for new tickets",
    "version": "1.0",
    "background": {
        "service_worker": "scripts/background.js"
    },
    "content_scripts": [{
        "matches": [
            "https://*.myconnectwise.net/*",
            "https://*.connectwise.com/*",
            "https://*.itboost.com/*"
        ],
        "all_frames": true,
        "js": ["scripts/content.js"]
    }],
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
      "https://emailjs.com/*",
      "https://api.emailjs.com/*"
    ]
}